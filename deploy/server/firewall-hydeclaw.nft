#!/usr/sbin/nft -f
# HydeClaw port isolation on the public-IP server (188.246.224.118).
# Public NIC = eth0. Allow only loopback, WireGuard (10.8.0.0/24),
# docker_wg (10.10.1.0/24), and LAN (192.168.0.0/16) to reach HydeClaw ports;
# drop them when they arrive on the public interface. SSH (22) is untouched.
table inet hydeclaw {
    set hydeclaw_ports {
        type inet_service
        elements = { 18789, 9011, 5432, 4317 }
    }
    chain input {
        type filter hook input priority -10; policy accept;
        iifname "lo" accept
        ip saddr { 10.8.0.0/24, 10.10.1.0/24, 192.168.0.0/16 } tcp dport @hydeclaw_ports accept
        iifname "eth0" tcp dport @hydeclaw_ports drop
    }
}
