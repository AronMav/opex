# Opex environment variables
# Copy this file to .env and fill in your values.
#
# POLICY: Only these 3 variables belong in .env.
# All other secrets (API keys, bot tokens, etc.) go into the secrets vault
# via the Web UI or POST /api/secrets — never in .env or config files.

# HTTP API authentication token — generate with: openssl rand -hex 32
OPEX_AUTH_TOKEN=your-auth-token-here

# Vault encryption key — generate with: openssl rand -hex 32
# WARNING: losing this key means losing all stored secrets. Back it up.
OPEX_MASTER_KEY=your-master-key-here

# PostgreSQL connection string
DATABASE_URL=postgresql://opex:opex@localhost:5432/opex
