# PostgreSQL.
#
# IMPORTANT — setup.sh replaces POSTGRES_PASSWORD with a 32-char random hex
# on first install and syncs it into config/opex.toml [database].url.
# The value below is a placeholder. If you copy this file by hand instead
# of running setup.sh, change the password before exposing the host to
# anything that can route to port 5432 — this file is committed to the
# repo and the literal "opex" was the previous default. Audit 2026-05-08.
POSTGRES_USER=opex
POSTGRES_PASSWORD=replace-me-with-a-random-secret

# ─────────────────────────────────────────────────────────────
# Phase 62 RES-06: Docker resource limits (per-service caps)
# ─────────────────────────────────────────────────────────────
# Memory is in docker units: k, m, g (e.g. 256m, 2g).
# CPU is fractional cores (e.g. 0.5 = half a core, 1.5 = 1.5 cores).
POSTGRES_MEM_LIMIT=2g
POSTGRES_CPUS=1.5
SEARXNG_MEM_LIMIT=256m
SEARXNG_CPUS=0.5
BROWSER_RENDERER_MEM_LIMIT=1g
BROWSER_RENDERER_CPUS=1.0
MCP_DEFAULT_MEM_LIMIT=384m
MCP_DEFAULT_CPUS=0.5
